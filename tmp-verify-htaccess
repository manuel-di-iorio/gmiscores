# Deny access to .htaccess
<Files .htaccess>
  Order allow,deny
  Deny from all
</Files>

# Disable directory browsing
Options -Indexes

# Redirect all traffic to the new domain
<IfModule mod_rewrite.c>
  RewriteEngine on

  # POST requests: proxy via PHP with _method param (RewriteCond evaluated before method resets)
  RewriteCond %{REQUEST_METHOD} =POST
  RewriteRule ^api/(.*)$ /proxy.php?path=api/$1&_method=POST [QSA,L]

  # Everything else: proxy
  RewriteRule ^api/(.*)$ /proxy.php?path=api/$1 [QSA,L]

  # Non-API: 301 redirect to new domain
  RewriteCond %{HTTP_HOST} ^gmiscores\.altervista\.org$ [NC]
  RewriteRule ^(.*)$ https://gmicloud.altervista.org/$1 [R=301,L]
</IfModule>
